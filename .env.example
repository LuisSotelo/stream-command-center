# =========================================================================
# 🧬 REVERSE AUCTION CONFIG - PROJECT SETUP
# =========================================================================

# --- 🚀 NEXTAUTH & SECURITY ---
# Local: http://localhost:3000 | Prod: https://tu-dominio.vercel.app
NEXTAUTH_URL="http://localhost:3000"
# Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET="un_string_aleatorio_muy_largo"

# --- 🎮 TWITCH API (Consola de Desarrolladores) ---
TWITCH_CLIENT_ID="tu_client_id"
TWITCH_CLIENT_SECRET="tu_client_secret"
NEXT_PUBLIC_TWITCH_CHANNEL="LuisHongo"

# --- 👤 ACCESS CONTROL (IDs Numéricos de Twitch) ---
# Tu ID personal (para lógica de Servidor y Cliente)
AUTHORIZED_TWITCH_ID="tu_id_owner_numerico"
NEXT_PUBLIC_OWNER_ID="tu_id_owner_numerico"
NEXT_PUBLIC_OWNER_EMAIL="tu_correo@ejemplo.com"

# Lista de moderadores (separados por coma, sin espacios)
AUTHORIZED_TWITCH_IDS="id_mod_1,id_mod_2,id_mod_3"

# --- ⚡ REAL-TIME & DATABASE (Pusher & Upstash) ---
NEXT_PUBLIC_PUSHER_KEY="tu_key"
NEXT_PUBLIC_PUSHER_CLUSTER="tu_cluster"
PUSHER_APP_ID="tu_id"
PUSHER_SECRET="tu_secret"

UPSTASH_REDIS_REST_URL="https://tu_database.upstash.io"
UPSTASH_REDIS_REST_TOKEN="tu_token"

# --- 🔴 STREAM & APP STATUS ---
# "true" para activar la subasta, "false" para pausar
NEXT_PUBLIC_STREAM_ACTIVE="false"

