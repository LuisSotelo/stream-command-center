# --- PUSHER CONFIG (Real-time events) ---
# Get these from Dashboard > App Keys
NEXT_PUBLIC_PUSHER_KEY="tu_key"
NEXT_PUBLIC_PUSHER_CLUSTER="tu_cluster"
PUSHER_APP_ID="tu_id"
PUSHER_SECRET="tu_secret"

# --- TWITCH AUTH (NextAuth.js) ---
# Register your app at: https://dev.twitch.tv/console
TWITCH_CLIENT_ID="tu_id"
TWITCH_CLIENT_SECRET="tu_secret"

# --- NEXTAUTH SETTINGS ---
# Generate a secure secret with: openssl rand -base64 32
NEXTAUTH_SECRET="un_string_aleatorio_muy_largo"
# Use http://localhost:3000 for local dev, change to your Vercel URL in production
NEXTAUTH_URL="http://localhost:3000"

# --- APP SETTINGS ---
# ID of the Twitch account authorized to access /admin (your ID)
# Find your ID at: https://gettr.io/ o vía Twitch API
AUTHORIZED_TWITCH_ID="tu_id_numerico_aqui"

# --- UPSTASH REDIS CONFIG (for real-time events) ---
# Sign up for a free Redis database at https://upstash.com/
UPSTASH_REDIS_REST_URL="https://tu_database.upstash.io"
UPSTASH_REDIS_REST_TOKEN="tu_token"

# --- STREAM STATUS (for testing) ---
NEXT_PUBLIC_STREAM_ACTIVE="false"